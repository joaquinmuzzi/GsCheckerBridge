# Shared secret expected by GsChecker (X-API-KEY)
BRIDGE_SHARED_SECRET=change_this_secret

# FastAPI listen port
BRIDGE_PORT=8000

# Browser mode:
# - true: headless (no GUI)
# - false: headed (visible unless USE_XVFB=true)
BRIDGE_HEADLESS=true

# Optional: run headed browser in hidden virtual display (recommended for Cloudflare)
# Requires xvfb-run installed.
USE_XVFB=false

# LocalTunnel public subdomain (optional but recommended)
# If empty, localtunnel will allocate a random URL each restart
LT_SUBDOMAIN=your-unique-subdomain

# LocalTunnel region
LT_REGION=eu
